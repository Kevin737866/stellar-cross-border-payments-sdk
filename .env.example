# Stellar Network Configuration
HORIZON_URL=https://horizon-testnet.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Contract Addresses (Replace with your deployed contract addresses)
ESCROW_CONTRACT_ADDRESS=YOUR_ESCROW_CONTRACT_ADDRESS_HERE
RATE_ORACLE_CONTRACT_ADDRESS=YOUR_RATE_ORACLE_CONTRACT_ADDRESS_HERE
COMPLIANCE_CONTRACT_ADDRESS=YOUR_COMPLIANCE_CONTRACT_ADDRESS_HERE

# Admin Configuration
ADMIN_SECRET_KEY=YOUR_ADMIN_SECRET_KEY_HERE
ADMIN_PUBLIC_KEY=YOUR_ADMIN_PUBLIC_KEY_HERE

# Rate Oracle Configuration
DEFAULT_DEVIATION_THRESHOLD=10
RATE_SOURCE_WEIGHTS=source1:50,source2:30,source3:20

# Compliance Configuration
MAX_TRANSACTION_AMOUNT=100000
RESTRICTED_JURISDICTIONS=IR,NP,KP

# Fee Configuration
DEFAULT_FEE=100
FEE_BUMP_MULTIPLIER=1.5
MAX_FEE=10000

# Timeout Configuration
DEFAULT_TIMEOUT=30000
TRANSACTION_TIMEOUT=60

# Development Settings
DEBUG=true
LOG_LEVEL=info
ENABLE_SIMULATION=true

# Security Settings
REQUIRE_MULTISIG=false
MIN_SIGNATURES=2
MAX_SIGNERS=10

# UI Configuration (for React components)
NEXT_PUBLIC_APP_NAME=Stellar Cross-Border Payments
NEXT_PUBLIC_APP_VERSION=0.1.0
NEXT_PUBLIC_SUPPORT_EMAIL=support@example.com
NEXT_PUBLIC_TERMS_URL=https://example.com/terms
NEXT_PUBLIC_PRIVACY_URL=https://example.com/privacy

# External Services
FRIENDBOT_URL=https://horizon-testnet.stellar.org/friendbot
EXPLORER_URL=https://stellar.expert/explorer/testnet
WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET_HERE

# Database (if using external storage)
DATABASE_URL=postgresql://user:password@localhost:5432/stellar_cross_border
REDIS_URL=redis://localhost:6379

# Monitoring and Analytics
SENTRY_DSN=YOUR_SENTRY_DSN_HERE
ANALYTICS_ID=YOUR_ANALYTICS_ID_HERE

# API Keys (if using external services)
COINGECKO_API_KEY=YOUR_COINGECKO_API_KEY_HERE
EXCHANGE_RATE_API_KEY=YOUR_EXCHANGE_RATE_API_KEY_HERE
